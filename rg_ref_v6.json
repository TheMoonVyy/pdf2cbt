                      "b": {
                        "$ref": "#/$defs/__schema6"
                      }
                    },
                    "required": [
                      "t",
                      "b"
                    ],
                    "additionalProperties": false
                  },
                  "exactlyTo": {
                    "type": "object",
                    "properties": {
                      "l": {
                        "anyOf": [
                          {
                            "$ref": "#/$defs/__schema6"
