                          {
                            "type": "null"
                          }
                        ]
                      },
                      "r": {
                        "$ref": "#/$defs/__schema6"
                      }
                    },
                    "required": [
                      "r"
                    ],
                    "additionalProperties": false
                  },
                  "offsetBy": {
                    "type": "object",
                    "properties": {
                      "l": {
                        "type": "number"
                      },
                      "r": {
                        "type": "number"
                      },
                      "t": {
                        "type": "number"
                      },
                      "b": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "within",
                  "exactlyTo"
                ],
                "additionalProperties": false
              }
