      "type": "object",
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "upper-latin",
            "lower-latin",
            "upper-pqrs",
            "lower-pqrs",
            "decimal",
            "upper-roman",
            "lower-roman"
          ]
        },
        "secondary": {
          "type": "string",
          "enum": [
            "upper-latin",
            "lower-latin",
            "upper-pqrs",
            "lower-pqrs",
            "decimal",
            "upper-roman",
            "lower-roman"
          ]
